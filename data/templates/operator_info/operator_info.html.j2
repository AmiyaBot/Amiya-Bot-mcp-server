<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ op.name or "operator" }}</title>
  <style>
    @font-face {
      font-family: "Harmony";
      {% if template_font_url %}
      src: url("{{ template_font_url }}") format("truetype");
      {% else %}
      src: local("HarmonyOS Sans SC"), local("Noto Sans CJK SC"), local("Noto Sans SC");
      {% endif %}
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }

    * {
      font-size: 18px;
      box-sizing: border-box;
      font-family: "Harmony", serif !important;
    }

    body {
      margin: 0;
    }

    #template {
      width: 1600px;
      min-height: 895px;
      background: {% if template_bg_data %}url("{{ template_bg_data }}"){% elif template_bg_url %}url("{{ template_bg_url }}"){% else %}linear-gradient(135deg, #757575, #4a4a4a){% endif %} center / cover no-repeat;
      position: relative;
    }

    .background {
      width: 100%;
      padding: 10px;
      background: rgb(255 255 255 / 30%) bottom 25px left 25% / auto calc(100% - 200px) no-repeat;
      display: flex;
      justify-content: space-between;
    }

    .left {
      width: 50%;
      min-height: 800px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .right {
      width: 47%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .operator-attr {
      display: flex;
      flex-wrap: wrap;
      font-size: 20px;
    }

    .operator-attr .attr {
      width: calc(100% / 3);
      margin-bottom: 5px;
      background: rgb(236 236 236 / 80%);
      display: flex;
      align-items: center;
    }

    .operator-attr .attr > div {
      width: calc(100% - 110px);
    }

    .operator-attr .attr span.a {
      color: #0069ff;
    }

    .operator-attr .attr span.b {
      color: #ff641e;
    }

    .operator-attr .attr::before {
      content: attr(title);
      width: 100px;
      padding: 2px 10px;
      margin-right: 10px;
      display: inline-block;
      background: #000;
      color: #fff;
    }

    .operator-name {
      margin-top: 30px;
      display: flex;
      flex-direction: column;
    }

    .operator-name .name {
      border-radius: 2px;
      background: rgb(255 255 255 / 50%);
      padding: 0 10px;
      display: flex;
      align-items: center;
      line-height: 1;
    }

    .operator-name .name > span {
      color: #fff;
      background: #000;
      padding: 5px 10px;
      border-radius: 4px;
      margin-right: 10px;
    }

    .class-info {
      display: flex;
      height: 60px;
    }

    .class-icon-box {
      width: 60px;
      padding: 5px;
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      text-align: center;
      line-height: 1.1;
      font-size: 14px;
    }

    .class-icon-box img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }

    .rarity {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-left: 10px;
      background: rgb(255 255 255 / 50%);
    }

    .tags {
      margin: 10px 0;
    }

    .tags span {
      padding: 5px 10px;
      margin-right: 5px;
      background: #000;
      color: #fff;
      border-radius: 4px;
    }

    .trait {
      font-size: 16px;
      padding: 10px;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      background: rgb(255 255 255 / 50%);
    }

    .skill-item {
      border-radius: 2px;
      padding: 15px 5px;
      background: rgb(48 48 48 / 75%);
      display: flex;
      color: #fff;
    }

    .skill-item:not(:last-child) {
      margin-bottom: 5px;
    }

    .skill-range {
      width: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .skill-desc {
      font-size: 16px !important;
    }

    .mark {
      color: #00b3ff;
    }

    .block-group {
      display: flex;
    }

    .block {
      width: 15px;
      height: 15px;
      margin: 1px;
    }

    .block.r {
      border: 1px solid #000;
      background: #fff;
    }

    .block.s {
      background: #000;
    }

    .range .block.r {
      border: 2px solid #000;
    }

    .title {
      color: #fff;
      background: #000;
      padding: 2px 10px;
      margin-bottom: 5px;
    }

    .exInfo {
      display: flex;
      align-items: flex-start;
      padding: 2px 10px;
      background: rgb(255 255 255 / 50%);
    }

    .exInfo.bs > div {
      padding-top: 5px;
    }

    .exInfo:last-child {
      margin-bottom: 10px;
    }

    .potential {
      display: flex;
      align-items: center;
    }

    .potential-icon {
      width: 25px;
      height: 25px;
      margin-right: 10px;
      background: #111;
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      line-height: 1;
      flex: none;
    }

    .bs-icon {
      width: 30px;
      height: 30px;
      margin: 0 5px;
      background: center / 100% no-repeat;
      flex: none;
    }

    .cv-table {
      border-collapse: collapse;
    }

    .cv-table td {
      vertical-align: top;
      padding: 0 8px 0 0;
    }

    .skill-type {
      display: flex;
      margin-bottom: 5px;
      flex-wrap: wrap;
    }

    .skill-type > div {
      margin-right: 5px;
      background: #737373;
      padding: 3px 8px;
      border-radius: 4px;
    }

    .skill-type > .tINCREASE_WITH_TIME,
    .skill-type > .t1 {
      background: #98c043 !important;
    }

    .skill-type > .tINCREASE_WHEN_ATTACK,
    .skill-type > .tINCREASE_WHEN_TAKEN_DAMAGE,
    .skill-type > .t2,
    .skill-type > .t4 {
      background: #ec7e4c !important;
    }
  </style>
</head>
<body>
<div id="template">
  {% macro render_attr(key, suffix="") -%}
    {% set base = base_attr.get(key, 0) %}
    {% set trust = trust_attr.get(key, 0) %}
    {% set mod = module_attr.get(key, 0) %}
    {{ base }}
    {%- if trust %}<span class="a">+{{ trust }}</span>{% endif -%}
    {%- if mod %}<span class="b">{{ ("+" ~ mod) | replace("+-", "-") }}</span>{% endif -%}
    {{ suffix }}
  {%- endmacro %}

  {% macro render_range_blocks(text) -%}
    {% for line in (text or "").splitlines() %}
      <div class="block-group">
        {% for char in line %}
          {% if char == "□" %}
            <div class="block r"></div>
          {% elif char == "■" %}
            <div class="block s"></div>
          {% else %}
            <div class="block"></div>
          {% endif %}
        {% endfor %}
      </div>
    {% endfor %}
  {%- endmacro %}

  {% set real_names = op.origin_names if op.origin_names else ([op.origin_name] if op.origin_name and op.origin_name != "未知" else []) %}
  <div class="background"{% if skin_url %} style="background-image: url('{{ skin_url }}');"{% endif %}>
    <div class="left">
      <div>
        <div class="operator-attr">
          <div class="attr" title="最大生命值"><div>{{ render_attr("maxHp") }}</div></div>
          <div class="attr" title="攻击力"><div>{{ render_attr("atk") }}</div></div>
          <div class="attr" title="防御力"><div>{{ render_attr("def") }}</div></div>
          <div class="attr" title="魔法抗性"><div>{{ render_attr("magicResistance") }}</div></div>
          <div class="attr" title="攻击速度"><div>{{ render_attr("attackSpeed") }}</div></div>
          <div class="attr" title="攻击间隔"><div>{{ render_attr("baseAttackTime") }}</div></div>
          <div class="attr" title="阻挡数"><div>{{ render_attr("blockCnt") }}</div></div>
          <div class="attr" title="部署费用"><div>{{ render_attr("cost") }}</div></div>
          <div class="attr" title="再部署时间"><div>{{ render_attr("respawnTime", "秒") }}</div></div>
          <div class="attr" title="势力"><div>{{ op.nation or "未知" }}</div></div>
          <div class="attr" title="阵营"><div>{{ op.group or "未知" }}</div></div>
          <div class="attr" title="队伍"><div>{{ op.team or "未知" }}</div></div>
          <div class="attr" title="种族"><div>{{ op.race or "未知" }}</div></div>
          <div class="attr" title="画师"><div>{{ op.drawer or "未知" }}</div></div>
          <div class="attr" title="生日"><div>{{ op.birthday or "未知" }}</div></div>
        </div>
        <div>
          <div class="title" style="width: 120px">潜能提升</div>
          {% for item in potential_list %}
            <div class="potential">
              {% if potential_icon_data %}
                <img class="potential-icon" src="{{ potential_icon_data }}" alt="potential">
              {% else %}
                <span class="potential-icon">✦</span>
              {% endif %}
              {{ item.potential_desc }}
            </div>
          {% endfor %}
        </div>
        <div>
          <div class="title" style="width: 120px;margin-top: 5px">真名</div>
          {% if real_names %}
            {% for name in real_names %}
              <div>{{ name }}</div>
            {% endfor %}
          {% else %}
            <div>未知</div>
          {% endif %}
        </div>
        <div>
          <div class="title" style="width: 120px;margin-top: 5px">CV</div>
          {% if op.cv and op.cv|length %}
            <table class="cv-table">
              {% for lang, names in op.cv.items() %}
                <tr>
                  <td>{{ lang }}：</td>
                  <td>{% if names is string %}{{ names }}{% else %}{{ names|join("、") }}{% endif %}</td>
                </tr>
              {% endfor %}
            </table>
          {% else %}
            <div>未知</div>
          {% endif %}
        </div>
      </div>
      <div class="operator-name" style="margin-bottom: 6px">
        <div class="range" style="margin: 15px 0">{{ render_range_blocks(op.range or "") }}</div>
        <div class="class-info">
          <div class="class-icon-box">
            {% if class_icon_data %}
              <img src="{{ class_icon_data }}" alt="{{ op.classes or '职业' }}图标">
            {% else %}
              {{ op.classes or "职业" }}
            {% endif %}
          </div>
          <div class="rarity">
            <div style="font-size: 30px;display: flex">{% for _ in range(op.rarity or 0) %}<i style="font-style: normal">★</i>{% endfor %}</div>
            <div>{{ op.classes or "未知" }} - {{ op.classes_sub or "未知" }}</div>
          </div>
        </div>
        <div class="tags">
          {% if op.is_sp %}<span style="background: #9c27b0">异格干员</span>{% endif %}
          {% for tag in (op.tags or []) %}<span>{{ tag }}</span>{% endfor %}
        </div>
        <div class="trait">{{ (op.operator_trait or "") | safe }}</div>
        <div class="name" style="padding-top: 10px; font-size: 50px">{{ op.name }}</div>
        <div class="name" style="padding-bottom: 10px; font-size: 30px">
          <span>{{ op.number or "-" }}</span>
          {{ op.en_name or "" }}
        </div>
      </div>
    </div>
    <div class="right">
      <div>
        <div>
          <div class="title">干员印象</div>
          <div class="exInfo">{{ op.profile or "无" }}</div>
          <i class="exInfo">「{{ op.impression or "无" }}」</i>
        </div>
        {% if op.potential_item %}
          <div>
            <div class="title">信物</div>
            <div class="exInfo">{{ op.potential_item }}</div>
          </div>
        {% endif %}
        <div>
          <div class="title">天赋</div>
          {% for item in talents_list %}
            <div class="exInfo">
              <div style="width: 120px">{{ item.get("talents_name", "") }}</div>
              <div style="width: calc(100% - 120px);padding-left: 10px">{{ (item.get("talents_desc", "") or "") | safe }}</div>
            </div>
          {% endfor %}
        </div>
        <div>
          <div class="title">基建技能</div>
          {% for item in building_skills %}
            {% set building_icon = (building_skill_icon_data.get(item.bs_icon or "") if building_skill_icon_data else "") %}
            <div class="exInfo bs">
              <div style="width: 60px">精英{{ item.bs_unlocked }}</div>
              <div class="bs-icon"{% if building_icon %} style="background-image: url('{{ building_icon }}')"{% endif %}></div>
              <div style="width: 100px">{{ item.bs_name }}</div>
              <div style="width: calc(100% - 160px);padding-left: 10px">{{ item.bs_desc }}</div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="skills">
        {% for sk in op.skills %}
          {% set last = (sk.levels[-1] if sk.levels else None) %}
          {% set last_sp = (last.sp if last and last.sp else None) %}
          {% set sp_type_map = (sp_type_name or {}) %}
          {% set skill_type_map = (skill_type_name or {}) %}
          {% set skill_icon = (skill_icon_data.get(sk.icon or "") if skill_icon_data else "") %}
          <div class="skill-item">
            <div style="width: 120px;text-align: center">
              <div>
                {% if skill_icon %}
                  <img style="width: 80px" src="{{ skill_icon }}" alt="{{ sk.name or '' }}图标">
                {% else %}
                  <div style="width: 80px;height: 80px;background: #555;margin: 0 auto"></div>
                {% endif %}
              </div>
              <div>{{ sk.name or "" }}</div>
            </div>
            <div style="width: calc(100% - 240px);padding: 0 10px">
              {% if last and last_sp %}
                <div class="skill-type">
                  <div class="t{{ last_sp.sp_type }}">{{ sp_type_map.get(last_sp.sp_type, last_sp.sp_type) }}</div>
                  <div>{{ skill_type_map.get(last.skill_type, last.skill_type) }}</div>
                  <div>技力 {{ last_sp.init_sp }}/{{ last_sp.sp_cost }}</div>
                  {% if last.duration and last.duration > 0 %}<div>持续 {{ last.duration }} 秒</div>{% endif %}
                </div>
                <div class="skill-desc">{{ (last.description or "") | safe }}</div>
              {% endif %}
            </div>
            <div class="skill-range">{% if last %}<div>{{ render_range_blocks(last.range or "") }}</div>{% endif %}</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
</body>
</html>
