<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ op.name or "operator" }}</title>
  <style>
    @font-face {
      font-family: "ExampleHarmonyOS";
      src: url("file:///home/coder/AmiyabotMCPServer/.temp/example/template/HarmonyOS_Sans_SC.ttf") format("truetype");
      font-display: swap;
    }

    :root {
      --panel-bg: rgba(255, 255, 255, 0.56);
      --dark-panel: rgba(47, 47, 47, 0.84);
      --dark-label: #050505;
      --text-main: #111;
      --text-light: #f7f7f7;
      --accent-blue: #0f8fff;
      --accent-orange: #ff7b1f;
      --accent-green: #98c043;
      --accent-red: #ec7e4c;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      background: #d9d9d9;
      color: var(--text-main);
      font-family: "ExampleHarmonyOS", "Noto Sans CJK SC", "Noto Sans SC", sans-serif;
    }

    body {
      min-width: 1600px;
    }

    #template {
      width: 1600px;
      min-height: 900px;
      overflow: hidden;
      position: relative;
      background:
        linear-gradient(146deg, rgba(255,255,255,0.92) 0 37%, transparent 37% 100%),
        linear-gradient(160deg, transparent 0 45%, rgba(58,58,58,0.16) 45% 62%, transparent 62% 100%),
        linear-gradient(192deg, transparent 0 26%, rgba(72,72,72,0.18) 26% 42%, transparent 42% 100%),
        linear-gradient(120deg, transparent 0 56%, rgba(255,255,255,0.72) 56% 66%, transparent 66% 100%),
        linear-gradient(0deg, #d7d7d7, #ededed 44%, #e6e6e6 100%);
    }

    #template::before,
    #template::after {
      content: "";
      position: absolute;
      pointer-events: none;
    }

    #template::before {
      width: 740px;
      height: 740px;
      left: 345px;
      top: 116px;
      background:
        linear-gradient(115deg, rgba(0,0,0,0.02), rgba(255,255,255,0.2)),
        radial-gradient(circle at 50% 30%, rgba(255,255,255,0.24), transparent 58%);
      border-radius: 18px;
      transform: skewX(-10deg);
      opacity: 0.7;
    }

    #template::after {
      width: 410px;
      height: 20px;
      left: 420px;
      bottom: 122px;
      background: rgba(255, 255, 255, 0.38);
      box-shadow: 0 0 0 1px rgba(255,255,255,0.1);
    }

    .page {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 0.9fr;
      gap: 34px;
      min-height: 900px;
      padding: 10px;
    }

    .left,
    .right {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .left {
      min-height: 880px;
    }

    .operator-attr {
      display: flex;
      flex-wrap: wrap;
      gap: 5px 0;
      margin-bottom: 8px;
      font-size: 18px;
    }

    .operator-attr .attr {
      width: calc(100% / 3);
      min-height: 38px;
      padding-right: 6px;
      background: rgba(236, 236, 236, 0.78);
      display: flex;
      align-items: center;
    }

    .operator-attr .attr::before {
      content: attr(title);
      width: 112px;
      min-height: 38px;
      padding: 2px 10px;
      margin-right: 10px;
      display: inline-flex;
      align-items: center;
      background: var(--dark-label);
      color: var(--text-light);
      line-height: 1.2;
    }

    .operator-attr .attr > div {
      width: calc(100% - 122px);
      line-height: 1.2;
      word-break: break-all;
    }

    .operator-attr span.a {
      color: var(--accent-blue);
    }

    .operator-attr span.b {
      color: var(--accent-orange);
    }

    .section-title {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 2px 12px;
      margin-bottom: 5px;
      background: var(--dark-label);
      color: var(--text-light);
      font-size: 18px;
      line-height: 1.2;
    }

    .title-wide {
      min-width: 120px;
    }

    .detail-panel {
      padding: 4px 10px;
      background: var(--panel-bg);
      line-height: 1.34;
    }

    .detail-panel + .detail-panel {
      margin-top: 2px;
    }

    .cv-table {
      border-collapse: collapse;
      width: 100%;
      background: var(--panel-bg);
    }

    .cv-table td {
      padding: 2px 10px 3px 10px;
      vertical-align: top;
    }

    .cv-table td:first-child {
      width: 122px;
      white-space: nowrap;
    }

    .potential-list {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .potential {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 2px 10px;
      background: rgba(255,255,255,0.42);
    }

    .potential-badge {
      width: 24px;
      height: 24px;
      border: 2px solid rgba(0,0,0,0.8);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 700;
      flex: none;
    }

    .identity {
      position: relative;
      margin-top: 12px;
      padding-top: 355px;
      min-height: 520px;
    }

    .identity::before {
      content: "";
      position: absolute;
      inset: 60px 55px 80px 110px;
      border-left: 1px solid rgba(0,0,0,0.06);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0.22)),
        radial-gradient(circle at 50% 10%, rgba(255,255,255,0.32), transparent 58%);
      border-radius: 12px;
      transform: skewX(-7deg);
      opacity: 0.95;
    }

    .identity::after {
      content: "{{ op.en_name or op.name or '' }}";
      position: absolute;
      left: 110px;
      right: 90px;
      top: 164px;
      text-align: center;
      font-size: 104px;
      letter-spacing: 0.08em;
      color: rgba(0,0,0,0.055);
      font-style: italic;
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .range-panel {
      display: flex;
      align-items: flex-end;
      gap: 20px;
      position: relative;
      z-index: 1;
      margin-bottom: 16px;
      min-height: 86px;
    }

    .range-grid {
      display: flex;
      flex-direction: column;
      gap: 2px;
      margin: 0;
      padding: 0;
    }

    .block-group {
      display: flex;
      gap: 2px;
      min-height: 16px;
    }

    .block {
      width: 16px;
      height: 16px;
    }

    .block.r {
      border: 1px solid #000;
      background: #fff;
    }

    .block.s {
      background: #000;
    }

    .range-panel .block {
      width: 17px;
      height: 17px;
    }

    .range-panel .block.r {
      border-width: 2px;
    }

    .class-block {
      display: flex;
      align-items: stretch;
      gap: 10px;
      margin-bottom: 10px;
      position: relative;
      z-index: 1;
    }

    .class-mark {
      width: 82px;
      height: 82px;
      padding: 6px;
      border: 5px solid #000;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.88);
      color: #111;
      font-size: 22px;
      font-weight: 700;
      line-height: 1.15;
      text-align: center;
      flex: none;
    }

    .class-meta {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 4px;
      min-width: 0;
    }

    .rarity-stars {
      display: flex;
      gap: 1px;
      font-size: 29px;
      line-height: 1;
    }

    .rarity-stars i {
      font-style: normal;
    }

    .class-line {
      font-size: 19px;
      line-height: 1.2;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin: 6px 0 10px 0;
      position: relative;
      z-index: 1;
    }

    .tags span {
      padding: 5px 11px;
      border-radius: 4px;
      background: #000;
      color: #fff;
      font-size: 16px;
      line-height: 1;
      white-space: nowrap;
    }

    .trait {
      position: relative;
      z-index: 1;
      padding: 10px 12px;
      margin-bottom: 12px;
      background: rgba(255,255,255,0.58);
      font-size: 16px;
      line-height: 1.45;
    }

    .operator-name {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
    }

    .operator-name .name-main,
    .operator-name .name-sub {
      display: inline-flex;
      align-items: center;
      min-height: 56px;
      padding: 0 14px;
      background: rgba(255,255,255,0.62);
      backdrop-filter: blur(1px);
    }

    .operator-name .name-main {
      font-size: 58px;
      line-height: 1;
    }

    .operator-name .name-sub {
      min-height: 48px;
      font-size: 30px;
      line-height: 1;
    }

    .operator-name .name-sub span {
      padding: 5px 10px;
      margin-right: 10px;
      border-radius: 4px;
      background: #000;
      color: #fff;
      font-size: 22px;
    }

    .right-top {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .impression-text {
      display: block;
      margin-top: 2px;
      font-style: italic;
    }

    .talent-row,
    .building-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 4px 10px;
      background: rgba(255,255,255,0.5);
    }

    .talent-row + .talent-row,
    .building-row + .building-row {
      margin-top: 2px;
    }

    .talent-name {
      width: 130px;
      flex: none;
      line-height: 1.35;
    }

    .talent-desc,
    .building-desc {
      flex: 1;
      line-height: 1.35;
    }

    .building-meta {
      width: 176px;
      flex: none;
      line-height: 1.35;
    }

    .skills {
      display: flex;
      flex-direction: column;
      gap: 5px;
      margin-top: 18px;
    }

    .skill-item {
      display: grid;
      grid-template-columns: 120px 1fr 126px;
      gap: 12px;
      align-items: stretch;
      padding: 14px 12px;
      background: var(--dark-panel);
      color: var(--text-light);
      border-radius: 2px;
      min-height: 136px;
    }

    .skill-side {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      text-align: center;
    }

    .skill-index {
      width: 82px;
      height: 82px;
      border-radius: 4px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.16), rgba(255,255,255,0.02)),
        linear-gradient(135deg, rgba(255,86,86,0.92), rgba(193,22,22,0.96));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 30px;
      font-weight: 700;
      letter-spacing: 0.04em;
      box-shadow: inset 0 0 0 2px rgba(255,255,255,0.12);
    }

    .skill-name {
      font-size: 17px;
      line-height: 1.3;
    }

    .skill-main {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .skill-type {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 8px;
      font-size: 16px;
    }

    .skill-type > div {
      padding: 4px 9px;
      border-radius: 4px;
      background: #737373;
      line-height: 1;
    }

    .skill-type > .tINCREASE_WITH_TIME,
    .skill-type > .t1 {
      background: var(--accent-green) !important;
    }

    .skill-type > .tINCREASE_WHEN_ATTACK,
    .skill-type > .tINCREASE_WHEN_TAKEN_DAMAGE,
    .skill-type > .t2,
    .skill-type > .t4 {
      background: var(--accent-red) !important;
    }

    .skill-desc {
      font-size: 17px;
      line-height: 1.42;
      color: rgba(255,255,255,0.98);
    }

    .skill-range {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 6px;
    }

    .skill-range .range-grid {
      align-items: flex-end;
    }

    .skill-range .block {
      width: 14px;
      height: 14px;
    }

    .skill-range .block.r {
      border-color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.94);
    }

    .skill-range .block.s {
      background: rgba(255, 255, 255, 0.94);
    }

    .mark {
      color: #1db1ff;
    }
  </style>
</head>
<body>
<div id="template">
  {% macro render_attr(key, suffix="") -%}
    {% set base = base_attr.get(key, 0) %}
    {% set trust = trust_attr.get(key, 0) %}
    {% set mod = module_attr.get(key, 0) %}
    {{ base }}
    {%- if trust %}<span class="a">+{{ trust }}</span>{% endif -%}
    {%- if mod %}<span class="b">{{ ("+" ~ mod) | replace("+-", "-") }}</span>{% endif -%}
    {{ suffix }}
  {%- endmacro %}

  {% macro render_range_blocks(text) -%}
    <div class="range-grid">
      {% for line in (text or "").splitlines() %}
        <div class="block-group">
          {% for char in line %}
            {% if char == "□" %}
              <div class="block r"></div>
            {% elif char == "■" %}
              <div class="block s"></div>
            {% else %}
              <div class="block"></div>
            {% endif %}
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  {%- endmacro %}

  <div class="page">
    <div class="left">
      <div>
        <div class="operator-attr">
          <div class="attr" title="最大生命值"><div>{{ render_attr("maxHp") }}</div></div>
          <div class="attr" title="攻击力"><div>{{ render_attr("atk") }}</div></div>
          <div class="attr" title="防御力"><div>{{ render_attr("def") }}</div></div>
          <div class="attr" title="魔法抗性"><div>{{ render_attr("magicResistance") }}</div></div>
          <div class="attr" title="攻击速度"><div>{{ render_attr("attackSpeed") }}</div></div>
          <div class="attr" title="攻击间隔"><div>{{ render_attr("baseAttackTime") }}</div></div>
          <div class="attr" title="阻挡数"><div>{{ render_attr("blockCnt") }}</div></div>
          <div class="attr" title="部署费用"><div>{{ render_attr("cost") }}</div></div>
          <div class="attr" title="再部署时间"><div>{{ render_attr("respawnTime", "秒") }}</div></div>
          <div class="attr" title="势力"><div>{{ op.nation or "未知" }}</div></div>
          <div class="attr" title="阵营"><div>{{ op.group or "未知" }}</div></div>
          <div class="attr" title="队伍"><div>{{ op.team or "未知" }}</div></div>
          <div class="attr" title="种族"><div>{{ op.race or "未知" }}</div></div>
          <div class="attr" title="画师"><div>{{ op.drawer or "未知" }}</div></div>
          <div class="attr" title="生日"><div>{{ op.birthday or "未知" }}</div></div>
        </div>

        {% if potential_list %}
          <div>
            <div class="section-title title-wide">潜能提升</div>
            <div class="potential-list">
              {% for item in potential_list %}
                <div class="potential">
                  <span class="potential-badge">P{{ item.potential_rank + 1 }}</span>
                  <span>{{ item.potential_desc }}</span>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        <div>
          <div class="section-title title-wide">真名</div>
          <div class="detail-panel">
            {% if op.origin_name and op.origin_name != "未知" %}
              {{ op.origin_name }}
            {% else %}
              未知
            {% endif %}
          </div>
        </div>

        <div>
          <div class="section-title title-wide">CV</div>
          {% if op.cv and op.cv|length %}
            <table class="cv-table">
              {% for lang, names in op.cv.items() %}
                <tr>
                  <td>{{ lang }}：</td>
                  <td>{% if names is string %}{{ names }}{% else %}{{ names|join("、") }}{% endif %}</td>
                </tr>
              {% endfor %}
            </table>
          {% else %}
            <div class="detail-panel">未知</div>
          {% endif %}
        </div>
      </div>

      <div class="identity">
        <div class="range-panel">
          {{ render_range_blocks(op.range or "") }}
        </div>

        <div class="class-block">
          <div class="class-mark">{{ op.classes or "职业" }}</div>
          <div class="class-meta">
            <div class="rarity-stars">{% for _ in range(op.rarity or 0) %}<i>★</i>{% endfor %}</div>
            <div class="class-line">{{ op.type or "未知" }} · {{ op.classes_sub or "未知" }}</div>
          </div>
        </div>

        <div class="tags">
          {% if op.is_sp %}<span style="background:#9c27b0;">异格干员</span>{% endif %}
          {% for t in (op.tags or []) %}<span>{{ t }}</span>{% endfor %}
        </div>

        <div class="trait">{{ (op.operator_trait or "") | safe }}</div>

        <div class="operator-name">
          <div class="name-main">{{ op.name }}</div>
          <div class="name-sub"><span>{{ op.number or "-" }}</span>{{ op.en_name or "" }}</div>
        </div>
      </div>
    </div>

    <div class="right">
      <div class="right-top">
        <div>
          <div class="section-title">干员印象</div>
          <div class="detail-panel">{{ op.profile or "无" }}</div>
          <div class="detail-panel impression-text">「{{ op.impression or "无" }}」</div>
        </div>

        {% if op.potential_item %}
          <div>
            <div class="section-title">信物</div>
            <div class="detail-panel">{{ op.potential_item }}</div>
          </div>
        {% endif %}

        {% if talents_list %}
          <div>
            <div class="section-title">天赋</div>
            {% for item in talents_list %}
              <div class="talent-row">
                <div class="talent-name">{{ item.get("talents_name", "") }}</div>
                <div class="talent-desc">{{ (item.get("talents_desc", "") or "") | safe }}</div>
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% if building_skills %}
          <div>
            <div class="section-title">基建技能</div>
            {% for item in building_skills %}
              <div class="building-row">
                <div class="building-meta">精英{{ item.bs_unlocked }} · {{ item.bs_name }}</div>
                <div class="building-desc">{{ item.bs_desc }}</div>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {% if op.skills and op.skills|length %}
        <div class="skills">
          {% for sk in op.skills %}
            {% set last = (sk.levels[-1] if sk.levels else None) %}
            <div class="skill-item">
              <div class="skill-side">
                <div class="skill-index">S{{ loop.index }}</div>
                <div class="skill-name">{{ sk.name or "" }}</div>
              </div>

              <div class="skill-main">
                {% if last %}
                  <div class="skill-type">
                    <div class="t{{ last.sp.sp_type }}">{{ sp_type_name.get(last.sp.sp_type, last.sp.sp_type) }}</div>
                    <div>{{ skill_type_name.get(last.skill_type, last.skill_type) }}</div>
                    {% if last.sp.sp_cost %}<div>技力 {{ last.sp.init_sp }}/{{ last.sp.sp_cost }}</div>{% endif %}
                    {% if last.duration and last.duration > 0 %}<div>持续 {{ last.duration }} 秒</div>{% endif %}
                  </div>
                  <div class="skill-desc">{{ (last.description or "") | safe }}</div>
                {% endif %}
              </div>

              <div class="skill-range">{% if last %}{{ render_range_blocks(last.range or "") }}{% endif %}</div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
</body>
</html>
